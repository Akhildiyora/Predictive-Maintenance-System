PORT=4000
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TELEMETRY_TOPIC=factory/+/telemetry

# Postgres
DB_USER=factory_admin
DB_PASSWORD=factory_password
DB_NAME=smart_factory
DB_HOST=localhost
DB_PORT=5432

# InfluxDB
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=super-secret-admin-token
INFLUXDB_ORG=factory_org
INFLUXDB_BUCKET=telemetry_bucket

# Thresholds
TEMP_THRESHOLD=75
VIBRATION_THRESHOLD=12
